# ===============================================
# StudyAI Local Development Environment
# ===============================================
# Copy this file to .env and fill in your values

# Django Core Settings
SECRET_KEY=django-insecure-local-dev-key-change-in-production-make-it-very-long
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite for local development)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# OpenAI Configuration (REQUIRED for AI features)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# JWT Settings
JWT_SIGNING_KEY=local-jwt-key-change-in-production

# CORS Settings (for frontend development)
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173

# AWS S3 Settings (Optional - for file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# ===============================================
# IMPORTANT: 
# 1. Copy this file to .env
# 2. Add your actual OpenAI API key
# 3. Never commit .env to git (it's in .gitignore)
# =============================================== 